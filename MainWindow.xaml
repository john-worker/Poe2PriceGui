<Window x:Class="Poe2PriceGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:Poe2PriceGui.Models"
        mc:Ignorable="d"
        Title="POE2 查价助手" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Icon="app.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <DataTemplate DataType="{x:Type models:ToastNotification}">
            <Border CornerRadius="8"
                    Background="{Binding Background}"
                    Padding="15,10"
                    Margin="0,0,0,8">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.3"/>
                </Border.Effect>
                <TextBlock Text="{Binding Message}"
                           Foreground="{Binding Foreground}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           MaxWidth="300"/>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#FFF4F4F6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TabControl TabStripPlacement="Left"
                    Margin="0"
                    Background="#FFEFEEF2"
                    BorderThickness="0"
                    Padding="0">
            <TabControl.Resources>
                <!-- 左侧导航页签样式：图标+文字，选中态左侧蓝色边条 + 浅蓝底 -->
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="#FF444450"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinWidth" Value="180"/>
                    <Setter Property="MinHeight" Value="62"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="RootBorder"
                                        Background="Transparent"
                                        BorderThickness="4,0,0,0"
                                        BorderBrush="Transparent"
                                        Margin="8,4,8,4"
                                        CornerRadius="0,8,8,0">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                Margin="18,0,18,0">
                                        <TextBlock x:Name="IconText"
                                                   Text="{TemplateBinding Tag}"
                                                   FontSize="22"
                                                   Foreground="#FF9A9AAB"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,14,0"/>
                                        <ContentPresenter ContentSource="Header"
                                                          VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="RootBorder" Property="BorderBrush" Value="#FF4A90D9"/>
                                        <Setter TargetName="RootBorder" Property="Background" Value="#FFE7F1FC"/>
                                        <Setter TargetName="IconText" Property="Foreground" Value="#FF4A90D9"/>
                                        <Setter Property="Foreground" Value="#FF1A5FBE"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="RootBorder" Property="Background" Value="#FFE5E5EA"/>
                                        <Setter TargetName="IconText" Property="Foreground" Value="#FF666680"/>
                                        <Setter Property="Foreground" Value="#FF333340"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <!-- 价格查看页 -->
            <TabItem Header="价格查看" Tag="📊">
                <Grid Margin="14" Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 标题与说明 -->
                    <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
                        <TextBlock Text="POE2 国服价格" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="数据来源：poecurrency.top" Foreground="Gray" FontSize="12"/>
                    </StackPanel>

                    <!-- 工具栏 -->
                    <ToolBarTray Grid.Row="1" Margin="0,0,0,10">
                        <ToolBar>
                            <Button Content="刷新价格" Command="{Binding RefreshCommand}" Padding="10,5" Margin="0,0,10,0"/>
                            <Separator Margin="10,0"/>
                            <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">
                            <Run Text="已加载："/>
                            <Run Text="{Binding Prices.Count, Mode=OneWay}"/>
                            <Run Text=" 条"/>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center" Foreground="DarkOrange">
                            <Run Text="已编辑："/>
                            <Run Text="{Binding EditedCount, Mode=OneWay}"/>
                            <Run Text=" 条"/>
                            </TextBlock>
                        </ToolBar>
                    </ToolBarTray>

                    <!-- 分类下拉框与搜索 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="分类：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              MinWidth="150"
                              VerticalAlignment="Center"
                              Margin="0,0,15,0"/>
                        <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsAllCategorySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="搜索：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="200"
                                 VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 价格表格 -->
                    <DataGrid Grid.Row="3"
                          ItemsSource="{Binding FilteredPrices}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F5F5F5">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPriceChanged}" Value="True">
                                        <Setter Property="Background" Value="#FFCDD2"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                        <Setter Property="Background" Value="#FFEEEE"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsEdited}" Value="True">
                                        <Setter Property="Background" Value="#FFF8E1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="物品名" IsReadOnly="True" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="{Binding IconImage}"
                                               Width="32" Height="32"
                                               Margin="0,0,8,0"
                                               Stretch="Uniform"
                                               VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ItemName}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="最新买" Binding="{Binding LatestBuy1, StringFormat=N2}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="最新卖" Binding="{Binding LatestSell1, StringFormat=N2}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="买均价" Binding="{Binding BuyAverage, StringFormat=N2}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="卖均价" Binding="{Binding SellAverage, StringFormat=N2}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="前日买" Binding="{Binding PreviousBuy1, StringFormat=N2}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="单位" Binding="{Binding CurrencyUnit}" IsReadOnly="True" Width="50"/>
                            <DataGridTextColumn Header="最终价(E)" Binding="{Binding PriceExalted, StringFormat=N2}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="DarkBlue"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="显示价" Binding="{Binding DisplayPrice}" IsReadOnly="True" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="DarkGreen"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridCheckBoxColumn Header="异常" Binding="{Binding HasError}" IsReadOnly="True" Width="50"/>
                            <DataGridTextColumn Header="异常原因" Binding="{Binding ErrorInfo}" IsReadOnly="True" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 状态栏 -->
                    <StatusBar Grid.Row="4" Margin="0,10,0,0">
                        <StatusBarItem>
                            <TextBlock Text="{Binding StatusMessage}"/>
                        </StatusBarItem>
                        <StatusBarItem HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="最后刷新：" Foreground="Gray"/>
                                <TextBlock Text="{Binding LastRefreshTime}" Margin="5,0,15,0"/>
                                <ProgressBar IsIndeterminate="True" Width="100" Height="16"
                                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </TabItem>

            <!-- 工具箱页 -->
            <TabItem Header="工具箱" Tag="🛠️">
                <Grid Margin="14" Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="工具箱" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <GroupBox Grid.Row="1" Header="价格补丁">
                        <StackPanel Orientation="Vertical" Margin="10">
                            <TextBlock Text="将当前价格导出为补丁文件。生成 zip 包不会修改游戏文件；安装补丁会备份并替换游戏目录下的 datc64。" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="导出价格 CSV" Command="{Binding ExportPricesCommand}" Padding="15,5" Margin="0,0,10,0"/>
                                <Button Content="导出补丁包 (zip)" Command="{Binding ExportPatchCommand}" Padding="15,5" Margin="0,0,10,0"/>
                                <Button Content="生成并安装补丁" Command="{Binding InstallPatchCommand}" Padding="15,5" Margin="0,0,10,0"/>
                                <Button Content="还原最新备份" Command="{Binding RestoreBackupCommand}" Padding="15,5"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <Path Fill="#FF181717" Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0" VerticalAlignment="Center"
                                      Data="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                                <TextBlock FontSize="11" VerticalAlignment="Center">
                                    <Run Text="参考来源：" Foreground="Gray"/>
                                    <Hyperlink NavigateUri="https://github.com/weixiao030/poe2_price"
                                               Foreground="#FF4A90D9"
                                               TextDecorations="Underline"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        <Run Text="poe2_price"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- 设置页 -->
            <TabItem Header="设置" Tag="⚙️">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="14" Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <GroupBox Grid.Row="4" Header="缓存管理">
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <Button Content="清理缓存图片" Command="{Binding CleanCacheCommand}" Padding="15,5" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding CacheStatusMessage}" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="1" Header="游戏目录" Margin="0,15,0,0">
                        <StackPanel Orientation="Vertical" Margin="10">
                            <TextBlock Text="POE2 游戏根目录（包含 PathOfExile2.exe 的目录）：" Margin="0,0,0,5" Foreground="Gray"/>
                            <DockPanel Margin="0,0,0,5">
                                <Button Content="自动查找" Command="{Binding AutoDetectGameDirectoryCommand}" Padding="10,3" DockPanel.Dock="Right" Margin="10,0,0,0"/>
                                <TextBox Text="{Binding GameDirectory, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <TextBlock>
                            <Run Text="检测到的版本：" Foreground="Gray"/>
                            <Run Text="{Binding DetectedGameMode}" Foreground="DarkBlue" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="2" Header="查价器" Margin="0,15,0,0">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Row="0" Grid.ColumnSpan="2"
                                      Content="启用查价器（Ctrl+D 识别鼠标上方装备）"
                                      IsChecked="{Binding PriceCheckerEnabled}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="热键：" VerticalAlignment="Center" Margin="0,0,10,5"/>
                            <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,5">
                                <Button Content="捕获热键" Command="{Binding CaptureHotkeyCommand}" Padding="10,3" DockPanel.Dock="Right" Margin="10,0,0,0"/>
                                <TextBox Text="{Binding PriceCheckerHotkey, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" IsReadOnly="True"/>
                            </DockPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="登录状态：" VerticalAlignment="Center" Margin="0,0,10,5"/>
                            <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,5">
                                <Button Content="浏览器登录" Command="{Binding OpenPriceCheckerLoginCommand}" Padding="10,3" DockPanel.Dock="Right" Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding LoginStatusText}"
                                           Foreground="{Binding LoginStatusColor}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="目标赛季：" VerticalAlignment="Center" Margin="0,0,10,5"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PriceCheckerLeague, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="点击「浏览器登录」打开内置浏览器，登录国服市集后自动获取 POESESSID。" Foreground="Gray" TextWrapping="Wrap"/>

                            <Button Grid.Row="5" Grid.ColumnSpan="2" Content="测试查价器（猎首腰带）"
                                    Command="{Binding TestPriceCheckerCommand}"
                                    Padding="10,5" Margin="0,8,0,0" HorizontalAlignment="Left"
                                    ToolTip="使用内置的猎首腰带文本模拟查价流程，测试登录和搜索是否正常"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Row="5" Header="日志" Margin="0,15,0,0">
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <Button Content="打开日志文件" Command="{Binding OpenLogCommand}" Padding="15,5" Margin="0,0,10,0"/>
                            <Button Content="清理日志" Command="{Binding CleanLogCommand}" Padding="15,5"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="6" Header="查价器调试数据" Margin="0,15,0,0">
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <Button Content="导出 stats 缓存"
                                    Command="{Binding ExportStatsCacheCommand}"
                                    Padding="15,5" Margin="0,0,10,0"
                                    ToolTip="拉取 POE2 交易 API 的 stats 数据并导出为 JSON 文件，便于排查词缀匹配问题。需先配置 POESESSID。"/>
                            <TextBlock Text="输出：data/stats_cache_debug.json"
                                       VerticalAlignment="Center"
                                       Foreground="Gray"
                                       FontSize="11"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="3" Header="通货价格查询" Margin="0,15,0,0">
                        <StackPanel Orientation="Vertical" Margin="10">
                            <TextBlock Text="Token（留空则使用公共接口）：" Margin="0,0,0,5" Foreground="Gray"/>
                            <TextBox Text="{Binding CurrencyPriceToken, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="填写 Token 后使用 summary_validate 接口获取数据，数据更稳定可靠。" Foreground="Gray" TextWrapping="Wrap" FontSize="11"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- 软件更新页 -->
            <TabItem Header="软件更新" Tag="🔄">
                <Grid Margin="14" Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="软件更新" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <GroupBox Grid.Row="1" Header="版本信息">
                        <StackPanel Orientation="Vertical" Margin="10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="当前版本：v" VerticalAlignment="Center" FontSize="14" Foreground="Gray"/>
                                <TextBlock Text="{Binding AppVersion}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                            <TextBlock Text="点击「检查更新」从 GitHub Releases 检查是否有新版本。发现新版本时可下载并自动安装，安装完成后应用将自动重启。软件使用GitHub Release更新，可能需要科学上网！"
                                       Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Button Content="🔄 检查更新"
                                    Command="{Binding CheckForUpdateCommand}"
                                    Padding="18,8" Margin="0,0,10,0"
                                    FontSize="14"
                                    HorizontalAlignment="Left"
                                    ToolTip="从 GitHub Releases 检查是否有新版本"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="2" Header="手动更新（无法访问 GitHub 时使用）" Margin="0,15,0,0">
                        <StackPanel Orientation="Vertical" Margin="10">
                            <TextBlock Text="如果无法访问 GitHub 或自动更新失败，请按以下步骤手动更新：" Foreground="Gray" Margin="0,0,0,8"/>
                            <TextBlock Text="1. 从 QQ 群文件下载最新的安装包（Poe2PriceGui-win-Setup.exe）"
                                       Foreground="Gray" Margin="10,0,0,4"/>
                            <TextBlock Text="2. 直接运行安装包，会自动覆盖安装旧版本"
                                       Foreground="Gray" Margin="10,0,0,8"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- BUG反馈页 -->
            <TabItem Header="BUG反馈" Tag="🐛">
                <Grid Margin="14" Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="BUG 反馈" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,25">
                        <TextBlock Text="遇到问题或有建议？点击下方按钮加入 QQ 群进行反馈："
                                   TextWrapping="Wrap" Margin="0,0,0,12" FontSize="13" Foreground="Gray"/>
                        <Button Content="🐛 加入 QQ 群反馈" Padding="18,8" HorizontalAlignment="Left"
                                FontSize="14" Cursor="Hand"
                                Click="OpenQQGroup_Click"
                                ToolTip="点击打开 QQ 群加入页面"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="QQ 群：" VerticalAlignment="Center" FontSize="13"/>
                        <Button Content="1001850913"
                                Click="CopyQQGroupNumber_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#FF1E6FFF" FontWeight="Bold" FontSize="13"
                                Cursor="Hand" VerticalAlignment="Center"
                                ToolTip="点击复制群号"/>
                        <TextBlock Text="（点击数字自动复制）" VerticalAlignment="Center"
                                   FontSize="11" Foreground="Gray" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 右上角 Toast 通知面板 -->
        <ItemsControl ItemsSource="{Binding Toasts}"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,15,15,0"
                  Panel.ZIndex="100">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>
</Window>
