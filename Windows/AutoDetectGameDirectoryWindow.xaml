<Window x:Class="Poe2PriceGui.Windows.AutoDetectGameDirectoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="自动查找游戏目录"
        Width="650"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="自动查找游戏目录"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="选择区服：" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="160"
                      ItemsSource="{Binding RegionOptions}"
                      SelectedItem="{Binding SelectedRegion}"
                      DisplayMemberPath="DisplayName"
                      VerticalContentAlignment="Center"/>
            <Button Content="重新查找"
                    Command="{Binding ScanCommand}"
                    Padding="12,3"
                    Margin="15,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1">
            <ListBox ItemsSource="{Binding FilteredCandidates}"
                     SelectedItem="{Binding SelectedCandidate}"
                     DisplayMemberPath="DisplayName"
                     Margin="5"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="应用"
                    Command="{Binding ApplyCommand}"
                    Padding="25,6"
                    IsDefault="True"/>
            <Button Content="取消"
                    Command="{Binding CancelCommand}"
                    Padding="25,6"
                    Margin="10,0,0,0"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
